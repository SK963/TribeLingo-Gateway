NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# CORS (comma-separated origins; include Vite preview :4173 if you use npm run preview)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173

# Postgres / Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gateway?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
# Min 16 characters (see gateway env schema)
JWT_SECRET=dev-only-change-me-16
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=gateway_token
AUTH_COOKIE_SECURE=false

# Google OAuth (ID token verification)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Encryption (AES-256-GCM) for OAuth tokens at rest (optional)
# 32 bytes base64, e.g. `openssl rand -base64 32`
DATA_ENCRYPTION_KEY_BASE64=

# Downstream services (gateway rewrites localhost → 127.0.0.1 for outbound calls)
TRANSLATION_SERVICE_URL=http://localhost:4001
POS_SERVICE_URL=http://localhost:4002
CHATBOT_SERVICE_URL=http://localhost:4003
# Docker-only: use host.docker.internal instead of localhost when services run on the host machine.

# Maps gateway/UI codes (e.g. lus_Latn) to Google Translate — keep in sync with translation_v2 KOKBOROK_LANGUAGE_CODE
KOKBOROK_LANGUAGE_CODE=trp

